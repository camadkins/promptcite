{
  "name": "promptcite",
  "version": "1.1.0",
  "description": "Cross-agent skill that adds /receipt — a structured AI-use disclosure command for student assignments",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "bin/install.js",
  "bin": {
    "promptcite": "bin/install.js",
    "promptcite-verify": "bin/verify.js"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/camadkins/promptcite.git"
  },
  "homepage": "https://github.com/camadkins/promptcite",
  "bugs": {
    "url": "https://github.com/camadkins/promptcite/issues"
  },
  "keywords": [
    "ai",
    "education",
    "academic-integrity",
    "disclosure",
    "citation",
    "claude-code",
    "gemini-cli",
    "cursor",
    "skill"
  ],
  "files": [
    "bin/",
    "src/",
    "GEMINI.md",
    "gemini-extension.json",
    "install.sh",
    "install.ps1",
    "LICENSE",
    "LICENSE-COMMERCIAL",
    "NOTICE.md",
    "CLA.md",
    "README.md",
    "INSTALL.md",
    "SECURITY.md"
  ],
  "scripts": {
    "dev": "node bin/install.js",
    "list": "node bin/install.js --list",
    "dry-run": "node bin/install.js --dry-run --all",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "node bin/install.js --version && node bin/install.js --list && node bin/install.js --help && node bin/install.js --dry-run --all",
    "test": "node --test tests/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
